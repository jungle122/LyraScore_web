<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lyrascore.dictionary.mapper.DictionaryMapper">

    <resultMap id="DictMap" type="com.lyrascore.dictionary.entity.Dictionary">
        <id     column="id"          property="id"/>
        <result column="dict_type"   property="dictType"/>
        <result column="dict_key"    property="dictKey"/>
        <result column="dict_value"  property="dictValue"/>
        <result column="sort_order"  property="sortOrder"/>
        <result column="is_active"   property="isActive"/>
    </resultMap>

    <select id="selectActiveByType" resultMap="DictMap">
        SELECT id, dict_type, dict_key, dict_value, sort_order, is_active
        FROM t_dictionary
        WHERE dict_type = #{dictType} AND is_active = 1
        ORDER BY sort_order ASC, id ASC
    </select>

</mapper>
